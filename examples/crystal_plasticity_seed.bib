@article{synthetic_bcc_cpfem_2026,
  title = {Synthetic BCC Ferritic Steel Crystal Plasticity Benchmark},
  author = {Lattice, Ada and Slip, Kai},
  journal = {Demo Journal of Computational Materials},
  year = {2026},
  doi = {10.0000/paperlattice.demo.1},
  keywords = {crystal plasticity, CPFEM, BCC steel, hardening, EBSD},
  abstract = {This synthetic record describes a BCC ferritic steel CPFEM study using a dislocation-density based hardening law. Validation data include stress-strain curves and EBSD texture evolution. The main limitation is transferability across strain rates and heat treatments.}
